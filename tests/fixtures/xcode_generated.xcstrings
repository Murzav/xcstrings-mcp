    "subscription.ask_to_buy.info_description" : {
      "comment" : "Ask to Buy explanation",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn \"Kaufanfrage\" aktiviert ist, benötigen Käufe die Zustimmung eines Erziehungsberechtigten."
          }
