    "onboarding.educational.science_facts" : {
      "comment" : "Scientific facts about breathing",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wussten Sie, dass achtsames Atmen wissenschaftlich nachweislich Stress reduziert, Ihnen hilft, erholsamer zu schlafen und hohen Blutdruck zu kontrollieren?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Did you know that mindful breathing is scientifically proven to reduce stress, help you sleep more restfully, and control high blood pressure?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Sabías que la respiración consciente está científicamente comprobada para reducir el estrés, ayudarte a dormir mejor y controlar la presión arterial alta?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saviez-vous que la respiration consciente est scientifiquement prouvée pour réduire le stress, vous aider à mieux dormir et contrôler l'hypertension artérielle ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo sapevi che la respirazione consapevole è scientificamente dimostrata per ridurre lo stress, aiutarti a dormire meglio e controllare la pressione alta?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マインドフル呼吸が科学的にストレス軽減、より良い睡眠、高血圧のコントロールに効果があることをご存知ですか？"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você sabia que a respiração consciente é cientificamente comprovada para reduzir o estresse, ajudá-lo a dormir melhor e controlar a pressão alta?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Знаешь ли ты, что осознанное дыхание научно доказано снижает стресс, помогает спать крепче и контролировать высокое давление?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чи знаєте ви, що усвідомлене дихання науково доведено знижує стрес, допомагає спати міцніше та контролювати високий кров'яний тиск?"
          }
        }
      }
    },
