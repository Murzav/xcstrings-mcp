    "subscription.legal.billing_info" : {
      "comment" : "Billing and cancellation information",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Abrechnung beginnt am Ende Ihrer kostenlosen Testversion, es sei denn, Sie kündigen. Pläne verlängern sich automatisch. Jederzeit über den App Store kündigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Billing starts at the end of your free trial unless you cancel. Plans renew automatically. Cancel anytime via the App Store."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La facturación comienza al final de tu prueba gratuita a menos que canceles. Los planes se renuevan automáticamente. Cancela en cualquier momento a través del App Store."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La facturation commence à la fin de votre essai gratuit sauf si vous annulez. Les plans se renouvellent automatiquement. Annulez à tout moment via l'App Store."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fatturazione inizia alla fine della tua prova gratuita a meno che non annulli. I piani si rinnovano automaticamente. Annulla in qualsiasi momento tramite l'App Store."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無料トライアル終了時にキャンセルしない限り、請求が開始されます。プランは自動更新されます。アップストア経由でいつでもキャンセルできます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A cobrança começa no final do seu teste gratuito, a menos que você cancele. Os planos se renovam automaticamente. Cancele a qualquer momento através da App Store."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оплата после пробного периода. Автопродление. Отмена в App Store."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оплата починається після завершення безкоштовного пробного періоду, якщо ви не скасуєте підписку. Плани поновлюються автоматично. Скасувати можна будь-коли через App Store."
          }
        }
      }
    },
