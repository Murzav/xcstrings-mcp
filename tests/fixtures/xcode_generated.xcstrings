    "onboarding.educational.breath_awareness" : {
      "comment" : "Breath awareness explanation",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es heißt \"Atembewusstsein\", und je konsequenter Sie sind, desto besser werden Sie sich fühlen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It's called \"breath awareness\", and the more consistent you are, the better you'll feel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se llama \"conciencia respiratoria\", y cuanto más consistente seas, mejor te sentirás."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est appelé \"conscience respiratoire\", et plus vous êtes régulier, mieux vous vous sentirez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si chiama \"consapevolezza del respiro\", e più sei costante, meglio ti sentirai."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これは「呼吸への意識」と呼ばれ、より一貫して実践するほど、より良い気分を味わえます。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chama-se \"consciência respiratória\", e quanto mais consistente você for, melhor se sentirá."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это называется «осознание дыхания», и чем регулярнее ты практикуешь, тем лучше себя чувствуешь."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це називається «усвідомлене дихання», і чим регулярніше ви практикуєте, тим краще почуватиметесь."
          }
        }
      }
    },
    "onboarding.educational.goal_setting" : {
      "comment" : "Goal setting instruction",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lassen Sie uns Ihr Ziel festlegen—entspannen, fokussieren oder besser schlafen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Now, let's set your goal—relax, focus, or sleep better."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahora, establezcamos tu objetivo: relajarte, concentrarte o dormir mejor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maintenant, définissons votre objectif : vous détendre, vous concentrer ou mieux dormir."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ora stabiliamo il tuo obiettivo: rilassarti, concentrarti o dormire meglio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "さあ、あなたの目標を設定しましょう—リラックス、集中、またはより良い睡眠。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agora vamos definir sua meta: relaxar, focar ou dormir melhor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Теперь давай поставим цель — расслабиться, сфокусироваться или лучше спать."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тепер давайте встановимо вашуу мету - розслабитися, зосередитися або краще спати."
          }
        }
      }
    },
