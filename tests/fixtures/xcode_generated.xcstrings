    "onboarding.quote.text" : {
      "comment" : "Inspirational quote about breathing",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Geist ist wie Wasser. Wenn er aufgewühlt ist, wird es schwierig zu sehen. Wenn er ruhig ist, wird alles klar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The mind is like water. When it's agitated, it becomes difficult to see. When it's calm, everything becomes clear."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mente es como el agua. Cuando está agitada, se vuelve difícil ver. Cuando está tranquila, todo se vuelve claro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'esprit est comme l'eau. Quand il est agité, il devient difficile de voir. Quand il est calme, tout devient clair."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mente è come l'acqua. Quando è agitata, diventa difficile vedere. Quando è calma, tutto diventa chiaro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "心は水のようなものです。波立っている時は見えにくく、穏やかな時にはすべてが明らかになります。"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A mente é como a água. Quando está agitada, torna-se difícil ver. Quando está calma, tudo se torna claro."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дыхание — это мост между телом и разумом"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розум як вода. Коли він збурений, стає важко бачити. Коли він спокійний, все стає зрозумілим."
          }
        }
      }
    },
