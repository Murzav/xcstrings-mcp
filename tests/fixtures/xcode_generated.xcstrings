          "stringUnit" : {
            "state" : "translated",
            "value" : "A rapid calming technique for use anywhere, anytime. Perfect for quick stress relief during a busy day"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una técnica de calma rápida para usar en cualquier lugar, en cualquier momento. Perfecta para alivio rápido del estrés durante un día ocupado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une technique de calme rapide à utiliser n'importe où, n'importe quand. Parfaite pour un soulagement rapide du stress pendant une journée chargée"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una tecnica di calma rapida da usare ovunque, in qualsiasi momento. Perfetta per un rapido sollievo dallo stress durante una giornata impegnativa"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "いつでもどこでも使える迅速な鎮静テクニック。忙しい日の素早いストレス解消に最適"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma técnica de acalmação rápida para usar em qualquer lugar, a qualquer hora. Perfeita para alívio rápido do estresse durante um dia ocupado"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Быстрая техника успокоения для использования где угодно и когда угодно. Идеально для быстрого снятия стресса в течение насыщенного дня"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Швидка техніка заспокоєння для використання де завгодно і коли завгодно. Ідеально для швидкого зняття стресу протягом насиченого дня"
          }
        }
      }
    },
    "technique.description.relax" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
